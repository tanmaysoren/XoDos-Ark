Disable DETECT_OS_ANDROID to avoid AOSP-private API usage in Mesa utility code.
Adapted from Termux: 0009-disable-termux-detection.patch

--- a/src/mesa/util/detect_os.h
+++ b/src/mesa/util/detect_os.h
@@ -24,7 +24,7 @@
  * Android defines __linux__, so DETECT_OS_LINUX and DETECT_OS_UNIX will
  * also be defined.
  */
-#if defined(__ANDROID__)
+#if 0
 #define DETECT_OS_ANDROID 1
 #endif
 

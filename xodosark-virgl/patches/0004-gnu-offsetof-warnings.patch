Suppress GNU extension warnings that the NDK toolchain triggers.
Adapted from Termux: 0002-avoid-gnu-offsetof-extensions-error.patch

--- a/meson.build
+++ b/meson.build
@@ -65,6 +65,8 @@
    '-Werror=switch',
    '-Wno-overlength-strings',
    '-Wno-missing-field-initializers',
+   '-Wno-gnu-offsetof-extensions',
+   '-Wno-gnu-pointer-arith',
    '-Werror=format',
 ]
 
